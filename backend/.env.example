# ============ App 模式 ============
# APP_MODE: dev | op
# dev = 详尽日志 + SQL echo + latency 打印 + CORS 全开
# op  = 精简稳定 + 异常脱敏 + CORS 收紧
# CLI 启动用 --dev / --op 可覆盖此值
APP_MODE=dev
APP_HOST=0.0.0.0
APP_PORT=8000
# 留空则按 mode 自动选 DEBUG/INFO
LOG_LEVEL=

# ============ HuggingFace 镜像与离线模式 ============
# 走国内镜像加速下载,config.settings 启动期自动注入到 os.environ
HF_ENDPOINT=https://hf-mirror.com
# 模型已通过 scripts/download_models.py 预下载;运行期默认不联网避免兼容性问题
# 要拉新模型时改成 0,或直接跑下载脚本
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ============ MySQL ============
# 注:docker/docker-compose.yml 把 MySQL 映射到宿主机 3307(避免和本机 MySQL 冲突)
# 如果你用 docker compose 起,这里写 3307;直连本机 MySQL 写 3306
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=rag
MYSQL_PASSWORD=ragpass
MYSQL_DB=rag_agent

# ============ Milvus ============
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_TEXT_COLLECTION=product_text
MILVUS_IMAGE_COLLECTION=product_image
MILVUS_TEXT_DIM=1024
MILVUS_IMAGE_DIM=512

# ============ Redis ============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CELERY_DB=1

# ============ LLM ============
# provider: deepseek | volcengine | openai
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=60

# ============ Embedding (text) ============
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_VERSION_TAG=v1

# ============ Embedding (multimodal / image) ============
MM_EMBEDDING_PROVIDER=local_clip
MM_EMBEDDING_MODEL=OFA-Sys/chinese-clip-vit-base-patch16
MM_EMBEDDING_VERSION_TAG=v1

# ============ Rerank (Cross-Encoder) ============
# provider: local_bge | cross_encoder | none
# - local_bge:用 FlagEmbedding 加载 BGE 系列(中文强)
# - cross_encoder:通用,可挂任意 HF cross-encoder(bce / MiniLM / 自训)
# - none:关闭精排
RERANK_PROVIDER=local_bge
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# 留给最终 LLM 的候选条数。3-5 即可,多了稀释 prompt 焦点
RERANK_TOP_K=5

# ============ Chunking (父子块) ============
FATHER_CHUNK_SIZE=800
CHILD_CHUNK_SIZE=200
CHUNK_OVERLAP=50
MIN_CHUNK_THRESHOLD=100

# ============ Query 优化 ============
QO_ENABLE_REWRITE=true
QO_ENABLE_HYDE=false
QO_ENABLE_MULTI_QUERY=false
QO_MULTI_QUERY_COUNT=3

# ============ Retrieval (多路召回 + 阈值) ============
RETRIEVAL_DENSE_TOP_K=30
RETRIEVAL_SPARSE_TOP_K=30
RETRIEVAL_ENABLE_BM25=true
RETRIEVAL_RRF_K=60
RETRIEVAL_FUSION_TOP_K=30
# rerank 后归一化分数阈值,低于则不引用(防幻觉)
# 0.3 太松,会让"球鞋 ≈ 灌篮高手"这类勉强匹配过线被 LLM 编造;0.4 是经验值。
RAG_SCORE_THRESHOLD=0.4
# 图像检索专用阈值 —— CLIP 余弦归一化后:同款 ≥ 0.65,同类 0.55~0.65,陌生图常 < 0.5。
# 用 0.3 会把"完全不相关的图"也匹到商品。默认 0.55。
RAG_IMAGE_SCORE_THRESHOLD=0.55

# ============ Vision (VLM 图像理解) ============
# provider: disabled | volcengine | openai
# - disabled:不调 VLM,陌生图只能靠 CLIP 视觉相似度匹配(可能不准)
# - volcengine:豆包 doubao-1.5-vision-pro,要实名认证 + 创建"推理接入点"
# - openai:OpenAI 协议,base_url 可指向任意兼容端点(智谱 / Together / Azure 等)
#
# 推荐 ✨:智谱 GLM-4V-Flash —— **完全免费,Flash 系列永久免费**,新用户送 2000 万 Token
#   1. https://open.bigmodel.cn 注册(微信扫码,不强制实名)
#   2. 控制台「API Keys」→ 新建 → sk-xxx
#   3. 用以下配置:
#        VISION_PROVIDER=openai
#        VISION_API_KEY=<智谱 key>
#        VISION_MODEL=glm-4v-flash
#        VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4  #url不一定正确请自己鉴别url
#
# 或火山豆包(免费额度更大但要实名 + 接入点 ID,步骤多):
#        VISION_PROVIDER=volcengine
#        VISION_API_KEY=<火山 key>
#        VISION_MODEL=ep-xxx     # 接入点 ID,不是模型本名
#        VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3 #url地址不一定正确
VISION_PROVIDER=disabled
VISION_API_KEY=
VISION_MODEL=glm-4v-flash
VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VISION_TIMEOUT=30
VISION_MAX_TOKENS=256

# ============ Memory (短期 Redis / 长期 MySQL+Milvus) ============
STM_RECENT_TURNS=8
STM_TOKEN_THRESHOLD=1500
STM_TTL_SECONDS=86400
LTM_TOP_K=5
LTM_SCORE_THRESHOLD=0.35
LTM_DECAY_DAYS=180
LTM_ENABLED=true

# ============ Web Search (联网搜索兜底) ============
# RERANK 候选为空 + 用户意图明确(SEARCH/RECOMMEND/DETAIL/COMPARE)时启动,
# 联网搜索拿外部信息回答,Respond 用专用 prompt 明确告知"本店没有"。
# provider: disabled | zhipu
# 智谱 web-search-pro 复用 VISION_API_KEY(都是智谱平台 API Key)即可,无需单独注册
WEB_SEARCH_PROVIDER=disabled
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 搜索引擎:search_std(基础) / search_pro(高阶,推荐) / search_pro_sogou / search_pro_quark
WEB_SEARCH_ENGINE=search_pro
WEB_SEARCH_COUNT=5
# 时间过滤:noLimit / oneDay / oneWeek / oneMonth / oneYear
WEB_SEARCH_RECENCY=noLimit
WEB_SEARCH_TIMEOUT=20

# ============ Celery ============
CELERY_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=600
CELERY_DEFAULT_QUEUE=default

# ============ Auth (JWT + bcrypt) ============
# 生产部署务必改成强随机值: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=1440
BCRYPT_ROUNDS=12

# ============ 对象存储 ============
# provider: minio | local_fs | s3
# - minio:走 docker-compose 起的 MinIO,正经对象存储
# - local_fs:落到 STORAGE_LOCAL_ROOT 目录,backend 会自动挂 /static/* 把图片暴露出来
STORAGE_PROVIDER=local_fs
STORAGE_ENDPOINT=127.0.0.1:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=rag-agent
STORAGE_SECURE=false
STORAGE_REGION=cn-north-1
STORAGE_LOCAL_ROOT=./data/uploads
STORAGE_PRESIGN_TTL=3600

# ============ 短信验证码 ============
# provider: mock | aliyun | tencent
# - mock:dev 调试用,验证码直接打到日志和响应里方便联调
# - aliyun/tencent:接真实短信网关,要填 AK/SK + 签名/模板 code
SMS_PROVIDER=mock
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_CODE_TTL=300
SMS_CODE_LENGTH=6
SMS_RATE_LIMIT_SECONDS=60
SMS_DAILY_LIMIT=10
