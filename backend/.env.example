# ============ App 模式 ============
# APP_MODE: dev | op
# dev = 详尽日志 + SQL echo + latency 打印 + CORS 全开
# op  = 精简稳定 + 异常脱敏 + CORS 收紧
# CLI 启动用 --dev / --op 可覆盖此值
APP_MODE=dev
APP_HOST=0.0.0.0
APP_PORT=8000
# 留空则按 mode 自动选 DEBUG/INFO
LOG_LEVEL=

# ============ HuggingFace 镜像与离线模式 ============
# 走国内镜像加速下载,config.settings 启动期自动注入到 os.environ
HF_ENDPOINT=https://hf-mirror.com
# 模型已通过 scripts/download_models.py 预下载;运行期默认不联网避免兼容性问题
# 要拉新模型时改成 0,或直接跑下载脚本
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ============ MySQL ============
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=rag
MYSQL_PASSWORD=ragpass
MYSQL_DB=rag_agent

# ============ Milvus ============
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_TEXT_COLLECTION=product_text
MILVUS_IMAGE_COLLECTION=product_image
MILVUS_TEXT_DIM=1024
MILVUS_IMAGE_DIM=512

# ============ Redis ============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CELERY_DB=1

# ============ LLM ============
# provider: deepseek | volcengine | openai
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=60

# ============ Embedding (text) ============
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_VERSION_TAG=v1

# ============ Embedding (multimodal / image) ============
MM_EMBEDDING_PROVIDER=local_clip
MM_EMBEDDING_MODEL=OFA-Sys/chinese-clip-vit-base-patch16
MM_EMBEDDING_VERSION_TAG=v1

# ============ Rerank (Cross-Encoder) ============
# provider: local_bge | cross_encoder | none
# - local_bge:用 FlagEmbedding 加载 BGE 系列(中文强)
# - cross_encoder:通用,可挂任意 HF cross-encoder(bce / MiniLM / 自训)
# - none:关闭精排
RERANK_PROVIDER=local_bge
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_K=10

# ============ Chunking (父子块) ============
FATHER_CHUNK_SIZE=800
CHILD_CHUNK_SIZE=200
CHUNK_OVERLAP=50
MIN_CHUNK_THRESHOLD=100

# ============ Query 优化 ============
QO_ENABLE_REWRITE=true
QO_ENABLE_HYDE=false
QO_ENABLE_MULTI_QUERY=false
QO_MULTI_QUERY_COUNT=3

# ============ Retrieval (多路召回 + 阈值) ============
RETRIEVAL_DENSE_TOP_K=30
RETRIEVAL_SPARSE_TOP_K=30
RETRIEVAL_ENABLE_BM25=true
RETRIEVAL_RRF_K=60
RETRIEVAL_FUSION_TOP_K=30
# rerank 后归一化分数阈值,低于则不引用(防幻觉)
RAG_SCORE_THRESHOLD=0.3

# ============ Celery ============
CELERY_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=600
CELERY_DEFAULT_QUEUE=default

# ============ Auth (JWT + bcrypt) ============
# 生产部署务必改成强随机值: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=1440
BCRYPT_ROUNDS=12

# ============ 对象存储 ============
# provider: minio | local_fs | s3
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=127.0.0.1:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=rag-agent
STORAGE_SECURE=false
STORAGE_REGION=cn-north-1
STORAGE_LOCAL_ROOT=./data/uploads
STORAGE_PRESIGN_TTL=3600

# ============ 短信验证码 ============
# provider: mock | aliyun | tencent
# - mock:dev 调试用,验证码直接打到日志和响应里方便联调
# - aliyun/tencent:接真实短信网关,要填 AK/SK + 签名/模板 code
SMS_PROVIDER=mock
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_CODE_TTL=300
SMS_CODE_LENGTH=6
SMS_RATE_LIMIT_SECONDS=60
SMS_DAILY_LIMIT=10
